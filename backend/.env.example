# Application
APP_NAME=BitMEX Growth Engineering Simulation
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=growth
POSTGRES_PASSWORD=growth_secret
POSTGRES_DB=growth_analytics
# Optional override (takes precedence over individual POSTGRES_* vars)
# DATABASE_URL=postgresql://growth:growth_secret@localhost:5432/growth_analytics

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL=redis://localhost:6379/0

# Security (Phase 1 — placeholders for later phases)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
RATE_LIMIT_PER_MINUTE=120

